# Azure App Registration (portal.azure.com)
# Redirect URI: https://YOUR-APP.vercel.app/api/auth/callback
AZURE_CLIENT_ID=your-client-id
AZURE_TENANT_ID=62ccb864-6a1a-4b5d-8e1c-397dec1a8258
AZURE_CLIENT_SECRET=your-client-secret

# Random 32+ char string — generate at: https://1password.com/password-generator/
SESSION_SECRET=change-this-to-a-random-32-char-string-minimum

# Set to your Vercel deployment URL after deploying
NEXTAUTH_URL=https://your-app.vercel.app
